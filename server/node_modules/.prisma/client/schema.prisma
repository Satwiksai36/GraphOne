datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  password      String
  name          String?
  role          String          @default("user") // "user" | "admin"
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bookmarks     Bookmark[]
  searchHistory SearchHistory[]
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType  String // "company" | "investor" | "product"
  itemId    String // Reference ID
  createdAt DateTime @default(now())

  @@unique([userId, itemType, itemId])
}

model SearchHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  createdAt DateTime @default(now())
}

model Category {
  id    String  @id @default(uuid())
  name  String  @unique
  slug  String  @unique
  count Int     @default(0)
  icon  String?
}

model Company {
  id                 String              @id // matches company slug e.g. "openai"
  name               String
  slug               String              @unique
  tagline            String
  description        String
  logo               String // matches logoUrl
  logoBg             String?
  website            String
  category           String? // primary category name
  stage              String?
  valuation          String?
  fundingTotal       String
  employeeCount      String
  foundedYear        Int
  hq                 String // matches location
  growthScore        Float?
  growthRate         Float? // matches growthRate (e.g. 150 for 150%)
  confidenceScore    Float?
  isTrending         Boolean             @default(false)
  isFeatured         Boolean             @default(false)
  isVerified         Boolean             @default(false)
  isPrivate          Boolean             @default(true)
  tags               String[]
  socialLinks        Json? // { twitter, linkedin, github, youtube }
  views7d            Int                 @default(0)
  trendingRank       Int?
  isEmerging         Boolean             @default(false)
  isUnicorn          Boolean             @default(false)
  isFrontierLab      Boolean             @default(false)
  isOpenSourceLeader Boolean             @default(false)
  rating             Float?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  ownership          Json? // array of categories & percentages
  openJobs           Json? // array of jobs
  acquisitions       Acquisition[]
  investments        CompanyInvestment[]
  founders           Founder[]
  investors          CompanyInvestor[]
  products           Product[]
  news               News[]
  fundingRounds      FundingRound[]
  researchPapers     ResearchPaper[]
  patents            Patent[]
  timeline           CompanyTimeline[]
  competitors        Competitor[]        @relation("CompanyCompetitors")
  competitorOf       Competitor[]        @relation("CompanyCompetitorOf")
}

model Founder {
  id        String    @id // e.g. "sam-altman"
  name      String
  role      String
  avatarUrl String
  bio       String?
  linkedin  String?
  twitter   String?
  companies Company[]
}

model Investor {
  id                     String            @id // e.g. "sequoia-capital"
  name                   String
  slug                   String            @unique
  logoUrl                String
  bio                    String
  location               String
  foundedYear            Int
  type                   String[] // e.g. ["VC", "Growth Equity"]
  isVerified             Boolean           @default(false)
  thesis                 String?
  preferredStages        String[]
  portfolioConcentration Json?
  investmentVelocity     Json?
  capitalFlow            Json?
  stageEvolution         Json?
  portfolioWinners       Json?
  followOnStrength       Json?
  networkStrength        Json?
  coInvestors            Json?
  marketInfluence        Json?
  exitIntelligence       Json?
  researchList           Json?
  relatedInvestors       String[] // Array of investor IDs
  stats                  Json? // { deals90d, leadInvestments, mostActiveStage, topPartner, topFocus }
  recentInvestments      Json? // array of recent investment objects
  companies              CompanyInvestor[]
}

model CompanyInvestor {
  companyId  String
  investorId String
  type       String // 'seed' | 'series' | 'growth'
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investor   Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@id([companyId, investorId])
}

model FundingRound {
  id            String   @id @default(uuid())
  companyId     String
  companyName   String
  round         String
  amount        String
  date          String
  leadInvestors String[]
  valuation     String?
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Product {
  id                String   @id // e.g. "chatgpt"
  name              String
  tagline           String
  description       String?
  logoUrl           String
  companyId         String
  categories        String[]
  votesCount        Int      @default(0)
  commentsCount     Int      @default(0)
  isTrending        Boolean  @default(false)
  isPopularRightNow Boolean  @default(false)
  releaseDate       String
  tags              String[]
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model News {
  id        String   @id // e.g. "openai-gpt5-launch"
  title     String
  date      String
  source    String
  companyId String?
  url       String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ResearchPaper {
  id        String  @id @default(uuid())
  title     String
  date      String
  link      String?
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Patent {
  id            String  @id @default(uuid())
  title         String
  category      String
  owner         String
  filedDate     String
  publishedDate String
  companyId     String
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Acquisition {
  id          String  @id @default(uuid())
  companyName String // name of acquired startup
  date        String
  focus       String
  amount      String?
  acquirerId  String
  acquirer    Company @relation(fields: [acquirerId], references: [id], onDelete: Cascade)
}

model CompanyInvestment {
  id        String  @id @default(uuid())
  company   String // name of target company
  focus     String
  stage     String
  amount    String?
  companyId String
  parent    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Competitor {
  id           String  @id @default(uuid())
  companyId    String
  competitorId String
  isAdjacent   Boolean @default(false)
  company      Company @relation("CompanyCompetitors", fields: [companyId], references: [id], onDelete: Cascade)
  competitor   Company @relation("CompanyCompetitorOf", fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([companyId, competitorId, isAdjacent])
}

model CompanyTimeline {
  id        String  @id @default(uuid())
  year      Int
  event     String
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
